        },
        {
          "id": "linear_algebra", "title": "Linear Algebra", "prerequisites": [],
          "subtopics": ["Vectors & vector spaces", "Matrix operations", "Eigenvalues & eigenvectors", "Matrix decomposition (SVD basics)", "Dot product & cosine similarity (for embeddings)"]
        },
        {
          "id": "toc_automata", "title": "Theory of Computation", "prerequisites": ["discrete_math"],
          "subtopics": ["Finite automata (DFA/NFA)", "Regular expressions & Thompson's construction", "Context-free grammars & CNF/GNF", "Pushdown automata", "Turing machines", "Pumping lemma", "Decidability & halting problem", "P vs NP basics"]
        }
      ]
    },
    {
      "module": "Programming Languages",
      "topics": [
