      "topics": [
        {
          "id": "discrete_math", "title": "Discrete Mathematics", "prerequisites": [],
          "subtopics": ["Set theory & functions", "Propositional & predicate logic", "Relations (equivalence, partial order)", "Combinatorics (permutations, combinations, pigeonhole)", "Graph theory basics", "Recurrence relations", "Number theory (GCD, modular arithmetic)"]
        },
        {
          "id": "probability_stats", "title": "Probability & Statistics", "prerequisites": [],
