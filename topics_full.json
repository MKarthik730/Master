        {"id": "interview_patterns", "title": "Interview Pattern Recognition", "prerequisites": ["greedy_backtracking", "tries_segment_trees"],
          "subtopics": ["Pattern-to-problem mapping (75-150 curated set)", "Time-boxed mock solving", "Communication while solving (thinking out loud)", "Edge case identification habits"]}
