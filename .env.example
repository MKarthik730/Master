# =============================================================================
# Master — CSE Placement Prep Tool | Environment Variables
# =============================================================================
# Copy this file to .env (or backend/.env) and adjust values.
#   cp .env.example .env
# =============================================================================

# --- Database ----------------------------------------------------------------
# SQLite (dev, no Docker):  sqlite+aiosqlite:///./master.db
# PostgreSQL (Docker):      postgresql+asyncpg://postgres:postgres@db:5432/study_gap
DATABASE_URL=sqlite+aiosqlite:///./master.db

# Set to "true" to log all SQL statements (debugging only)
DB_ECHO=false

# --- Embedding Model (sentence-transformers) ----------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# --- Reranker (cross-encoder) ------------------------------------------------
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- LLM Gateway — Ollama (local, primary) -----------------------------------
# Default assumes Ollama is running on localhost:11434
# In Docker, point to: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# --- LLM Gateway — Fallback (OpenAI-compatible API) --------------------------
# Optional. Only needed when Ollama is unavailable or response quality is low.
# FALLBACK_API_KEY=sk-...
# FALLBACK_API_URL=https://api.openai.com/v1
# FALLBACK_MODEL=gpt-4o-mini

# --- Chunking -----------------------------------------------------------------
CHUNK_TARGET_TOKENS=400
CHUNK_OVERLAP_TOKENS=50

# --- Retrieval ----------------------------------------------------------------
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_RERANK=10
FINAL_K=5

# --- Hybrid Search Weights ----------------------------------------------------
DENSE_WEIGHT=0.5
SPARSE_WEIGHT=0.5

# --- Confidence Threshold ----------------------------------------------------
# If no chunk clears this threshold, respond "not found in document"
CONFIDENCE_THRESHOLD=0.3

# --- Domain -------------------------------------------------------------------
DEFAULT_DOMAIN=placement_mastery

# --- Syllabus Path ------------------------------------------------------------
# Path to the topics_full.json syllabus file. By default it looks in the
# project root (parent of backend/).
# SYLLABUS_PATH=./topics_full.json

# --- App ----------------------------------------------------------------------
DEBUG=false
CORS_ORIGINS=*

# --- Redis (Docker only) ------------------------------------------------------
# Used for caching embeddings and query responses. Falls back gracefully if
# Redis is unreachable.
# REDIS_URL=redis://redis:6379/0
