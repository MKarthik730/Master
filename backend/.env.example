# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/study_gap

# Redis
REDIS_URL=redis://localhost:6379/0

# Embedding model
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# Reranker
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# LLM Gateway - Local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# LLM Gateway - Fallback (optional)
FALLBACK_API_KEY=
FALLBACK_API_URL=https://api.openai.com/v1
FALLBACK_MODEL=gpt-4o-mini

# Chunking
CHUNK_TARGET_TOKENS=400
CHUNK_OVERLAP_TOKENS=50

# Retrieval
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_RERANK=10
FINAL_K=5

# Defaults
DEFAULT_DOMAIN=theory_of_computation
DEBUG=false
